# Python分析API（backend/）のベースURL。
# 未設定の場合、Next.js側は開発用の固定ダミーデータで動作する（フォールバック）。
#
# ローカル開発: backend/README.md の手順でFastAPIサーバーを起動した上で
#   PYTHON_ANALYSIS_API_URL=http://localhost:8000
#
# Vercel等にデプロイする場合: 公開したPython APIのURL（例: Renderの場合
# https://<service-name>.onrender.com）を設定する。末尾のスラッシュは不要。
# 設定手順は docs/09_deployment.md を参照。
PYTHON_ANALYSIS_API_URL=

# 依頼者確認用ステージング環境（数ヶ月運用予定）の誤アクセス防止用パスコード。
# 未設定の場合、ローカル開発を妨げないようゲート自体が無効になる（proxy.ts参照）。
# Vercelにデプロイする場合のみ設定する。サーバー側でのみ参照する値であり、
# クライアントに露出しない（NEXT_PUBLIC_ プレフィックスを付けないこと）。
# 本格的な認証ではなく、誤アクセス・検索露出を減らすための最低限の保護。
# 設定手順は docs/09_deployment.md の「簡易パスコードガード」を参照。
STAGING_ACCESS_CODE=

# --- 以下はPython分析API（backend/）側の環境変数（Next.js側の.env.localではなく、
# backend/を起動する側 or Renderで設定する）。Next.js自体はこれらを参照しない。
# backend/README.md の「AI Overview比較のprovider mode」も参照。

# aiOverviewComparisonセクションのprovider切り替え（backend/services/ai_overview_provider.py）。
# mock（デフォルト・固定開発データ）/ off（セクション無効化） / dataforseo（DataForSEO
# Sandboxへ実際に接続する。DATAFORSEO_API_ENV=sandbox かつ認証情報設定済みの場合のみ。
# Live API（本番相当のホスト）への接続はまだ実装されていない）。未設定時はmock。
AI_OVERVIEW_PROVIDER_MODE=mock

# true にした場合のみ、POST /analyzeのリクエストボディの `aiOverviewMode` フィールドで
# 上記のデフォルトを1リクエスト単位で上書きできるようにする（主にテスト用）。
# 未設定/false の場合、リクエストの `aiOverviewMode` は無視され、常に
# AI_OVERVIEW_PROVIDER_MODE の値が使われる。誤って費用が発生するモードを
# リクエストだけで有効化できないようにするための安全策。
ALLOW_AI_OVERVIEW_MODE_OVERRIDE=false

# --- DataForSEO関連（backend/services/dataforseo_settings.py、
# backend/services/dataforseo_client.py）。
# dataforseo mode + DATAFORSEO_API_ENV=sandbox + 認証情報設定済みの場合のみ、
# 実際にDataForSEO Sandbox（sandbox.dataforseo.com）へHTTP接続する。
# DATAFORSEO_API_ENV=live は今回もサポート外で、常に外部APIを呼ばず
# "unavailable" を返す（DATAFORSEO_LIVE_API_ENABLED=true でも同様）。
# 値は絶対に本物をここ（.env.example）に書かないこと。実際の値はRenderの
# Environment Variablesにのみ設定し、GitHubにコミットしない・フロントエンドへは
# 渡さない。詳細は backend/README.md の「DataForSEO Sandbox接続」、
# docs/07_decisions.md を参照。

# DataForSEOアカウントの認証情報。login はメールアドレス形式のアカウントID、
# password はAPIパスワード。両方とも空欄のままで問題ない
# （未設定時は is_configured=false になり、dataforseo modeは
# 「credentials are not configured」という安全な理由文言のみを返す）。
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# DataForSEOのSandbox/Live切り替え。sandbox（デフォルト・テスト用、費用は
# 発生しない）/ live（本番相当、費用が発生し得る。今回も未実装のため常に
# "unavailable"になる）。未設定・不正値はsandboxにフォールバックする。
DATAFORSEO_API_ENV=sandbox

# true にした場合のみ、DATAFORSEO_API_ENV=live と組み合わせて実際にLive API
# を使うことを許可する候補になる（実際にLive APIを呼ぶコード自体がまだ
# 存在しないため、trueにしても呼び出しは発生しない）。未設定/falseならLive
# APIは絶対に使われない。
DATAFORSEO_LIVE_API_ENABLED=false

# 1回の POST /analyze でDataForSEOへ投げてよい最大リクエスト数（Sandbox接続は
# 常に1リクエストのみ発行するため、現状は未参照。将来の複数キーワード対応
# 向けの上限値）。未設定時は1。不正値・負の値は1に、上限（10）を超える値は
# 10にフォールバックする。
DATAFORSEO_REQUEST_LIMIT_PER_ANALYZE=1

# dataforseo modeでリクエストするDataForSEO SERPエンドポイント。
# google_ai_mode_live_advanced（デフォルト・推奨。Sandboxで"Vercel"を検索した
# 際にai_overview項目を確実に返すことを手動確認済み）/
# google_organic_live_advanced（旧実装との互換用。ai_overview項目を確実には
# 返さないため非推奨）。未設定・不正値はgoogle_ai_mode_live_advancedに
# フォールバックする。エンドポイント名の"live"はDataForSEO独自の即時応答方式の
# 名称で、DATAFORSEO_API_ENV=sandbox/liveの環境選択とは別軸（Sandbox時は
# 常にsandbox.dataforseo.comへのみ接続する）。
DATAFORSEO_SERP_ENDPOINT=google_ai_mode_live_advanced

# DataForSEOへ送るSERPリクエストのlocation_code。未設定・不正値（整数変換
# できない）は2392（日本）にフォールバックする。
DATAFORSEO_LOCATION_CODE=2392

# DataForSEOへ送るSERPリクエストのlanguage_code。未設定・空文字はja
# にフォールバックする。
DATAFORSEO_LANGUAGE_CODE=ja

# DataForSEOへ送るSERPリクエストのdevice。desktop/mobileのみ許可。
# 未設定・不正値はdesktopにフォールバックする。
DATAFORSEO_DEVICE=desktop

# DataForSEOへ送るSERPリクエストのos。windows/macos/linux/android/iosを
# 想定（網羅的ではない）。未設定・不正値はwindowsにフォールバックする。
DATAFORSEO_OS=windows
