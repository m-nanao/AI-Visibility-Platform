# Python分析API（backend/）のベースURL。
# 未設定の場合、Next.js側は開発用の固定ダミーデータで動作する（フォールバック）。
#
# ローカル開発: backend/README.md の手順でFastAPIサーバーを起動した上で
#   PYTHON_ANALYSIS_API_URL=http://localhost:8000
#
# Vercel等にデプロイする場合: 公開したPython APIのURL（例: Renderの場合
# https://<service-name>.onrender.com）を設定する。末尾のスラッシュは不要。
# 設定手順は docs/09_deployment.md を参照。
PYTHON_ANALYSIS_API_URL=

# 依頼者確認用ステージング環境（数ヶ月運用予定）の誤アクセス防止用パスコード。
# 未設定の場合、ローカル開発を妨げないようゲート自体が無効になる（proxy.ts参照）。
# Vercelにデプロイする場合のみ設定する。サーバー側でのみ参照する値であり、
# クライアントに露出しない（NEXT_PUBLIC_ プレフィックスを付けないこと）。
# 本格的な認証ではなく、誤アクセス・検索露出を減らすための最低限の保護。
# 設定手順は docs/09_deployment.md の「簡易パスコードガード」を参照。
STAGING_ACCESS_CODE=

# --- 以下はPython分析API（backend/）側の環境変数（Next.js側の.env.localではなく、
# backend/を起動する側 or Renderで設定する）。Next.js自体はこれらを参照しない。
# backend/README.md の「AI Overview比較のprovider mode」も参照。

# aiOverviewComparisonセクションのprovider切り替え（backend/services/ai_overview_provider.py）。
# mock（デフォルト・固定開発データ）/ off（セクション無効化） / dataforseo（未実装。
# 指定しても外部APIは呼ばず、meta.sections.aiOverviewComparisonは"unavailable"になる）。
# 未設定時はmock。DataForSEO本接続はまだ実装されていない。
AI_OVERVIEW_PROVIDER_MODE=mock

# true にした場合のみ、POST /analyzeのリクエストボディの `aiOverviewMode` フィールドで
# 上記のデフォルトを1リクエスト単位で上書きできるようにする（主にテスト用）。
# 未設定/false の場合、リクエストの `aiOverviewMode` は無視され、常に
# AI_OVERVIEW_PROVIDER_MODE の値が使われる。誤って費用が発生するモードを
# リクエストだけで有効化できないようにするための安全策。
ALLOW_AI_OVERVIEW_MODE_OVERRIDE=false

# --- DataForSEO関連（backend/services/dataforseo_settings.py）。
# 本タスクではまだDataForSEO APIへの実際の接続は行っていない
# （AI_OVERVIEW_PROVIDER_MODE=dataforseoを指定しても外部APIは呼ばれない）。
# これらは将来の本接続に備えた設定の受け皿であり、値は絶対に本物を
# ここ（.env.example）に書かないこと。実際の値はRenderのEnvironment
# Variablesにのみ設定し、GitHubにコミットしない・フロントエンドへは渡さない。
# 詳細は backend/README.md の「DataForSEO設定（dataforseo_settings.py）」、
# docs/07_decisions.md を参照。

# DataForSEOアカウントの認証情報。login はメールアドレス形式のアカウントID、
# password はAPIパスワード。両方とも空欄のままで問題ない
# （未設定時は is_configured=false になり、dataforseo modeは
# 「credentials are not configured」という安全な理由文言のみを返す）。
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# DataForSEOのSandbox/Live切り替え。sandbox（デフォルト・テスト用、費用は
# 発生しない）/ live（本番相当、費用が発生し得る）。未設定・不正値はsandbox
# にフォールバックする。
DATAFORSEO_API_ENV=sandbox

# true にした場合のみ、DATAFORSEO_API_ENV=live と組み合わせて実際にLive API
# を使うことを許可する（本タスクでは実際にLive APIを呼ぶコード自体がまだ
# 存在しないため、trueにしても呼び出しは発生しない）。未設定/falseならLive
# APIは絶対に使われない。
DATAFORSEO_LIVE_API_ENABLED=false

# 1回の POST /analyze でDataForSEOへ投げてよい最大リクエスト数（将来の実装
# 向けの上限値。費用の急増を防ぐための安全弁）。未設定時は1。不正値・負の値
# は1に、上限（10）を超える値は10にフォールバックする。
DATAFORSEO_REQUEST_LIMIT_PER_ANALYZE=1
